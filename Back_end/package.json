{
  "name": "cuidabem-backend",
  "version": "2.0.0",
  "description": "CuidaBem — API REST de Produção para Gestão de Cuidados à Pessoa Idosa",
  "main": "dist/server.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only --exit-child src/server.ts",
    "build": "tsc --project tsconfig.json",
    "start": "node dist/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:generate": "prisma generate",
    "db:migrate:dev": "prisma migrate dev --name init",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "db:seed": "ts-node prisma/seed.ts",
    "lint": "eslint src --ext .ts --fix"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@prisma/client": "5.10.0",
    "@types/uuid": "^10.0.0",
    "axios": "^1.17.0",
    "bcrypt": "6.0.0",
    "compression": "^1.8.1",
    "cors": "2.8.6",
    "date-fns": "^4.4.0",
    "dotenv": "^17.4.2",
    "express": "5.2.1",
    "express-rate-limit": "^8.5.2",
    "helmet": "8.1.0",
    "jsonwebtoken": "9.0.3",
    "morgan": "1.10.1",
    "multer": "1.4.5-lts.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^14.0.0",
    "winston": "^3.19.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.11.5",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "prisma": "5.10.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
