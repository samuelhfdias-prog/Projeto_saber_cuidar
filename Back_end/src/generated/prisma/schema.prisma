generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Idoso {
  id                   Int       @id @default(autoincrement())
  nome                 String
  data_nascimento      DateTime?
  cpf                  String    @unique
  sexo                 String?
  peso                 Float?
  condicoes_medicinais String?
  criado_em            DateTime  @default(now())
  atualizado_em        DateTime  @updatedAt

  doencas           IdosoDoenca[]
  medicamentos      Medicamento[]
  alimentacoes      Alimentacao[]
  prontuarios       ProntuarioDiario[]
  uploads           MediaUpload[]
  relacaoCuidadores CuidadorIdoso[]
  relatorios        Relatorio[]
  feedAtividades    FeedAtividade[]

  @@index([cpf])
  @@map("idoso")
}

model Doenca {
  id          Int     @id @default(autoincrement())
  nome_doenca String
  codigo_cid  String?
  categoria   String?

  idosos IdosoDoenca[]

  @@map("doenca")
}

model IdosoDoenca {
  id               Int       @id @default(autoincrement())
  id_doenca        Int
  id_idoso         Int
  data_diagnostico DateTime?
  observacao       String?

  doenca Doenca @relation(fields: [id_doenca], references: [id], onDelete: Cascade)
  idoso  Idoso  @relation(fields: [id_idoso], references: [id], onDelete: Cascade)

  @@map("idoso_doenca")
}

model Medicamento {
  id                Int     @id @default(autoincrement())
  id_idoso          Int
  nome_medicamento  String
  via_administracao String?
  frequencia        String?
  dosagem           String?
  horario           String?
  observacao        String?

  idoso Idoso @relation(fields: [id_idoso], references: [id], onDelete: Cascade)

  @@index([id_idoso])
  @@map("medicamento")
}

model Cuidador {
  id            Int      @id @default(autoincrement())
  nome          String
  email         String   @unique
  senha_hash    String
  sexo          String?
  cpf           String   @unique
  telefone      String?
  turno         String?
  criado_em     DateTime @default(now())
  atualizado_em DateTime @updatedAt

  acompanhamentos   AcompanhamentoCuidador[]
  alimentacoes      Alimentacao[]
  prontuarios       ProntuarioDiario[]
  uploads           MediaUpload[]
  relacaoIdosos     CuidadorIdoso[]
  relatorios        Relatorio[]
  feedAtividades    FeedAtividade[]

  @@index([email])
  @@map("cuidador")
}

model AcompanhamentoCuidador {
  id            Int       @id @default(autoincrement())
  id_cuidador   Int
  humor         String?
  sono          String?
  nivel_energia String?
  observacao    String?
  dia           DateTime?

  cuidador Cuidador @relation(fields: [id_cuidador], references: [id], onDelete: Cascade)

  @@index([id_cuidador])
  @@map("acompanhamento_cuidador")
}

model Alimentacao {
  id          Int     @id @default(autoincrement())
  id_cuidador Int
  id_idoso    Int
  refeicao    String
  horario     String
  quantidade  String
  observacao  String?

  cuidador Cuidador @relation(fields: [id_cuidador], references: [id], onDelete: Restrict)
  idoso    Idoso    @relation(fields: [id_idoso], references: [id], onDelete: Cascade)

  @@index([id_cuidador])
  @@index([id_idoso])
  @@map("alimentacao")
}

model MediaUpload {
  id            Int      @id @default(autoincrement())
  id_cuidador   Int
  nome_original String
  caminho       String
  tipo_mime     String
  tamanho_bytes Int
  tipo_midia    String
  analise       String?
  id_idoso      Int?
  criado_em     DateTime @default(now())

  cuidador Cuidador @relation(fields: [id_cuidador], references: [id], onDelete: Cascade)
  idoso    Idoso?   @relation(fields: [id_idoso], references: [id], onDelete: SetNull)

  @@map("media_upload")
}

model ProntuarioDiario {
  id          Int      @id @default(autoincrement())
  id_idoso    Int
  id_cuidador Int
  data        DateTime @default(now())
  diurese     String   // ex: "Normal", "Ausente", "Intensa"
  evacuacao   String   // ex: "Normal", "Ausente", "Diarreia"
  hidratacao  String   // ex: "500ml", "1L"
  observacao  String?

  idoso    Idoso    @relation(fields: [id_idoso], references: [id], onDelete: Cascade)
  cuidador Cuidador @relation(fields: [id_cuidador], references: [id], onDelete: Restrict)

  @@index([id_idoso])
  @@index([id_cuidador])
  @@map("prontuario_diario")
}

model Relatorio {
  id           Int      @id @default(autoincrement())
  id_idoso     Int
  id_cuidador  Int
  tipo         String   // "Semanal" | "Mensal"
  data_inicio  DateTime
  data_fim     DateTime
  resumo_geral String?
  status_geral String?
  criado_em    DateTime @default(now())

  idoso    Idoso    @relation(fields: [id_idoso], references: [id], onDelete: Cascade)
  cuidador Cuidador @relation(fields: [id_cuidador], references: [id], onDelete: Restrict)

  @@index([id_idoso])
  @@index([id_cuidador])
  @@map("relatorio")
}

model CuidadorIdoso {
  id          Int      @id @default(autoincrement())
  id_idoso    Int
  id_cuidador Int
  papel       String   @default("cuidador") // "titular" | "cuidador" | "familiar"
  criado_em   DateTime @default(now())

  idoso    Idoso    @relation(fields: [id_idoso], references: [id], onDelete: Cascade)
  cuidador Cuidador @relation(fields: [id_cuidador], references: [id], onDelete: Cascade)

  @@unique([id_idoso, id_cuidador])
  @@index([id_idoso])
  @@index([id_cuidador])
  @@map("cuidador_idoso")
}

model FeedAtividade {
  id          Int      @id @default(autoincrement())
  id_idoso    Int
  id_cuidador Int
  tipo        String   // "medicamento" | "alimentacao" | "prontuario" | "upload" | "relatorio" | "login"
  descricao   String
  criado_em   DateTime @default(now())

  idoso    Idoso    @relation(fields: [id_idoso], references: [id], onDelete: Cascade)
  cuidador Cuidador @relation(fields: [id_cuidador], references: [id], onDelete: Cascade)

  @@index([id_idoso])
  @@index([id_cuidador])
  @@map("feed_atividade")
}
