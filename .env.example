# ─────────────────────────────────────────────────────────────────────────────
# CuidaBem API — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais.
# NUNCA versione o arquivo .env com dados reais.
# ─────────────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
DATABASE_URL="mysql://root:suasenha@localhost:3306/cuidabem"
JWT_SECRET="SUBSTITUA_POR_UMA_CHAVE_FORTE_DE_MINIMO_64_CARACTERES_AQUI"
JWT_EXPIRES_IN=2h
BCRYPT_SALT_ROUNDS=12
CORS_ORIGINS=http://localhost:4200,http://localhost:4201
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=100
